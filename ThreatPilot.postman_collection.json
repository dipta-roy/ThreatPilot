            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"ollama\",\n  \"model_name\": \"qwen2.5-vl\",\n  \"endpoint\": \"http://localhost:11434\",\n  \"max_tokens\": 4096\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/ai/config",
