{
  "info": {
    "name": "ThreatPilot API",
    "description": "API collection for the ThreatPilot Web Designer Backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Project Management",
      "item": [
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/project",
              "host": ["{{base_url}}"],
              "path": ["api", "project"]
            },
            "description": "Loads the active project."
          }
        },
        {
          "name": "Get Project Metadata",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/project/metadata",
              "host": ["{{base_url}}"],
              "path": ["api", "project", "metadata"]
            },
            "description": "Retrieves lightweight project metadata."
          }
        },
        {
          "name": "Save Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"components\": [],\n  \"boundaries\": [],\n  \"custom_component_types\": [],\n  \"threats\": [],\n  \"vulnerabilities\": [],\n  \"mitigationRequirements\": []\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/project",
              "host": ["{{base_url}}"],
              "path": ["api", "project"]
            },
            "description": "Saves current diagrams and state back to project files."
          }
        },
        {
          "name": "Autosave Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"components\": []\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/project/autosave",
              "host": ["{{base_url}}"],
              "path": ["api", "project", "autosave"]
            },
            "description": "Performs periodic background auto-saving."
          }
        },
        {
          "name": "Save Architecture Image",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"image_data\": \"data:image/jpeg;base64,...\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/project/image",
              "host": ["{{base_url}}"],
              "path": ["api", "project", "image"]
            },
            "description": "Accepts base64 encoded JPG data to save as architecture.jpg."
          }
        }
      ]
    },
    {
      "name": "2. AI Infrastructure & Orchestration",
      "item": [
        {
          "name": "Get Prompt Config",
          "request": {
            "method": "GET",
