            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"business_context\": \"\",\n  \"risk_preferences\": \"\",\n  \"custom_instructions\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/project/prompt_config",
