            "description": "Fetches a list of locally available models from Ollama."
          }
        },
        {
          "name": "Run Threat Analysis",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/ai/analyze",
              "host": ["{{base_url}}"],
              "path": ["api", "ai", "analyze"]
            },
            "description": "Runs STRIDE/LINDDUN threat analysis against DFD components."
          }
        },
        {
          "name": "Get Threat Analysis Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/ai/status",
              "host": ["{{base_url}}"],
              "path": ["api", "ai", "status"]
            },
            "description": "Polls the real-time progress of an ongoing threat analysis batch."
          }
        },
        {
          "name": "Compile Mitigations",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/ai/mitigations",
              "host": ["{{base_url}}"],
              "path": ["api", "ai", "mitigations"]
            },
            "description": "Initiates a background Map-Reduce review to group and compile security requirements."
          }
        },
        {
          "name": "Get Mitigations Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/ai/mitigations/status",
              "host": ["{{base_url}}"],
              "path": ["api", "ai", "mitigations", "status"]
            }
          }
        },
        {
          "name": "Generate XAI Reasoning",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"threat_id\": \"T-001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/ai/reason",
              "host": ["{{base_url}}"],
              "path": ["api", "ai", "reason"]
            },
            "description": "Triggers Explainable AI deep-dives for a threat, vulnerability, or requirement."
          }
        }
      ]
    },
    {
      "name": "3. Authentication & Security",
      "item": [
        {
          "name": "Get Auth Portal",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth",
              "host": ["{{base_url}}"],
              "path": ["auth"]
            },
            "description": "Serves the standalone HTML portal for entering the PIN."
          }
        },
        {
          "name": "Verify PIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "pin",
                  "value": "12345678",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify"]
            },
            "description": "Validates the PIN and issues a secure cookie."
          }
        }
      ]
    },
    {
      "name": "4. Exports",
      "item": [
        {
          "name": "Export HTML Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/export/html",
              "host": ["{{base_url}}"],
              "path": ["api", "export", "html"]
            }
