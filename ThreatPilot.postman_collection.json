              "path": ["api", "project", "prompt_config"]
            },
            "description": "Retrieves the active project's business context and prompt instructions."
          }
        },
        {
          "name": "Update Prompt Config",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
